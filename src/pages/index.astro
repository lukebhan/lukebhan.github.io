---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Research from '../components/Research.astro';
import About from '../components/About.astro';
import Teaching from '../components/Teaching.astro';
import Footer from '../components/Footer.astro';
---
<Base>
  <Nav />
  <main>
    <Hero />
    <Research />
    <About />
    <Teaching />
  </main>
  <Footer />
</Base>

<script>
  // Honor reduced-motion: stop the autoplaying hero demos.
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('.demo-cell video').forEach((v) => { v.removeAttribute('autoplay'); v.pause(); });
  }
  const av = document.getElementById('avatar');
  function avFallback() {
    const d = document.createElement('div');
    d.className = 'avatar-fallback'; d.textContent = 'LB';
    av.replaceWith(d);
  }
  if (av) {
    if (av.complete && av.naturalWidth === 0) avFallback();
    else av.addEventListener('error', avFallback);
  }
  const links = Array.from(document.querySelectorAll('.nav-links a[href^="#"]'));
  const map = {};
  links.forEach((a) => { const id = a.getAttribute('href').slice(1); const s = document.getElementById(id); if (s) map[id] = a; });
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) { links.forEach((a) => a.classList.remove('active')); map[e.target.id]?.classList.add('active'); }
    });
  }, { rootMargin: '-45% 0px -50% 0px', threshold: 0 });
  Object.keys(map).forEach((id) => obs.observe(document.getElementById(id)));
</script>
