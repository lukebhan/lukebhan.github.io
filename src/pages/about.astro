---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
import experience from '../data/experience.json';
const { name, aboutPage: a, links } = site;
const title = 'About · Luke Bhan';
const description = 'About Luke Bhan, a PhD candidate at UC San Diego working at the intersection of scientific machine learning and control theory, from a foundation in physics, applied mathematics, and computer science.';

// bowtie diagram geometry
const headLinks = [{ label: 'Research', href: '/research' }, ...links.filter((l) => l.href !== '/research_statement.pdf')];
const rootY = (i) => 70 + i * 90;   // 3 foundations
const domY = (j) => 88 + j * 72;    // 3 application domains
---
<Base title={title} description={description}>
  <Nav base="/" />
  <main>
    <article class="ab">
      <div class="wrap">
        <header class="ab-head">
          <img class="ab-portrait" src="/portrait_full.jpg" alt={`Portrait of ${name}`} />
          <div class="ab-head-text">
            <p class="eyebrow">{a.eyebrow}</p>
            <h1>{name}</h1>
            <p class="ab-identity" set:html={a.identity}></p>
            <div class="ab-links">{headLinks.map((l) => <a href={l.href}>{l.label}</a>)}</div>
          </div>
        </header>

        <div class="ab-intro">
          <div class="ab-bio">
            <p set:html={a.bio}></p>
          </div>
          <figure class="bowtie">
            <svg viewBox="0 0 760 320" role="img" aria-label="Foundations in physics, applied mathematics, and computer science feed my Ph.D. research, scientific ML and control theory, applied across PDE systems, robotics, and biological systems.">
              {a.roots.map((r, i) => (
                <>
                  <path d={`M234 ${rootY(i)} C 256 ${rootY(i)}, 256 160, 278 160`} fill="none" stroke="var(--hair)" stroke-width="1.5"></path>
                  <rect x="24" y={rootY(i) - 22} width="210" height="44" rx="10" fill="#fff" stroke="var(--hair)"></rect>
                  <text x="129" y={rootY(i) + 5} text-anchor="middle" class="bt-root">{r}</text>
                </>
              ))}
              {a.domains.map((d, j) => (
                <>
                  <path d={`M482 160 C 504 160, 504 ${domY(j)}, 526 ${domY(j)}`} fill="none" stroke={d.color} stroke-opacity="0.45" stroke-width="1.5"></path>
                  <rect x="526" y={domY(j) - 22} width="210" height="44" rx="10" fill={d.color}></rect>
                  <text x="631" y={domY(j) + 5} text-anchor="middle" class="bt-dom">{d.label}</text>
                </>
              ))}
              <rect x="278" y="126" width="204" height="68" rx="14" fill="var(--indigo)"></rect>
              <text x="380" y="156" text-anchor="middle" class="bt-hub">Scientific ML</text>
              <text x="380" y="180" text-anchor="middle" class="bt-hub">× control theory</text>
              <path class="ub" d="M278 202 L278 208 L482 208 L482 202"></path>
              <path class="ub" d="M380 208 L380 214"></path>
              <text x="380" y="231" text-anchor="middle" class="bt-brace">Ph.D. research</text>
              <path class="ub" d="M24 282 L24 288 L234 288 L234 282"></path>
              <path class="ub" d="M129 288 L129 294"></path>
              <text x="129" y="311" text-anchor="middle" class="bt-brace">Foundations</text>
              <path class="ub" d="M526 282 L526 288 L736 288 L736 282"></path>
              <path class="ub" d="M631 288 L631 294"></path>
              <text x="631" y="311" text-anchor="middle" class="bt-brace">Applications</text>
            </svg>
            <figcaption>My Ph.D. distills a foundation in physics, mathematics, and computing into one method for controlling systems, now reaching across a growing range of domains.</figcaption>
          </figure>
        </div>

        <section class="ab-block">
          <h2>The path (so far...)</h2>
          <ol class="timeline">
            {a.timeline.map((t) => (
              <li>
                <div class="tl-when">{t.when}</div>
                <div class="tl-body">
                  <div class="tl-where">{t.where}</div>
                  <p>{t.detail}</p>
                </div>
              </li>
            ))}
          </ol>
        </section>

        <div class="ab-grid">
          <section class="ab-block">
            <h2>Education</h2>
            {a.education.map((e) => (
              <div class="ab-edu">
                <div class="ab-when">{e.when}</div>
                <div><div class="ab-deg">{e.what}</div><div class="ab-sub">{e.where}</div></div>
              </div>
            ))}
          </section>
          <section class="ab-block">
            <h2>Honors</h2>
            <ul class="ab-list">{a.honors.map((h) => <li set:html={h}></li>)}</ul>
            <h2 class="ab-sub-h">Grants &amp; fellowships</h2>
            <ul class="ab-list">{a.grants.map((g) => <li set:html={g}></li>)}</ul>
          </section>
        </div>

        <section class="ab-block">
          <h2>Industry &amp; national-lab experience</h2>
          {experience.map((e) => (
            <div class="row exp">
              <div class="meta">{e.year}</div>
              <div class="logo-cell">
                {e.logo && <img class="exp-logo" src={e.logo} alt={`${e.org} logo`} height="24" loading="lazy" decoding="async" />}
              </div>
              <div class="x">{e.role}, <b>{e.org}</b> <span class="d2">· {e.detail}</span></div>
            </div>
          ))}
        </section>

        <section class="ab-block">
          <h2>Leadership &amp; service</h2>
          <ul class="ab-list wide">{a.service.map((s) => <li set:html={s}></li>)}</ul>
          <h2 class="ab-sub-h">Mentoring</h2>
          {a.mentorIntro && <p class="mentor-intro">{a.mentorIntro}</p>}
          <ul class="mentor-list">
            {a.mentees.map((m) => (
              <li>
                <div class="mn-head">
                  <span class="mn-name">{m.name}</span>
                  <span class="mn-meta">{m.year} · {m.from}{m.to ? <> → now <b>{m.to}</b></> : <>, <span class="mn-cur">currently a student</span></>}</span>
                </div>
                {m.did && (
                  <p class="mn-did">{(m.didLink || m.paper)
                    ? <a href={m.didLink || `/publications?q=${encodeURIComponent(m.paper.title)}`} target={m.didLink ? '_blank' : undefined} rel={m.didLink ? 'noopener' : undefined}>{m.did}</a>
                    : m.did}</p>
                )}
              </li>
            ))}
          </ul>
        </section>

        <section class="ab-block">
          <h2>Outside research</h2>
          <div class="ab-life">
            <figure><img src="/dog.jpeg" alt="My dog, Erwin" loading="lazy" decoding="async" /><figcaption>My dog, Erwin.</figcaption></figure>
            <figure><img src="/hockey.jpeg" alt="Playing ice hockey" loading="lazy" decoding="async" /><figcaption>Learning hockey as an adult, one skate at a time (I'm on the right).</figcaption></figure>
          </div>
          <p class="ab-life-lead">Outside the lab, most of my time goes to my dog, Erwin, and, lately, to learning ice hockey as an adult, despite barely being able to skate when I started.</p>
        </section>

        <p class="ab-back"><a href="/#top">← Back to home</a></p>
      </div>
    </article>
  </main>
  <Footer />
</Base>

<style>
  .ab { padding: 40px 0 0; }
  .ab-head { display: flex; align-items: center; gap: 28px; margin-bottom: 26px; }
  .ab-portrait { width: 168px; aspect-ratio: 3 / 4; border-radius: 12px; object-fit: cover; object-position: center top; border: 1px solid var(--hair); background: var(--panel); flex: none; box-shadow: 0 14px 34px -22px rgba(58,46,99,.5); }
  .ab-head h1 { font-family: var(--display); font-weight: 600; font-size: clamp(30px, 6vw, 42px); line-height: 1.05; letter-spacing: -.02em; margin: 8px 0 0; color: var(--ink); }
  .ab-identity { font-size: clamp(16px, 2.2vw, 19px); color: var(--muted); line-height: 1.45; margin: 10px 0 0; max-width: 32em; }
  .ab-identity .usd { color: var(--teal); font-weight: 600; }

  /* compact intro: bio + diagram */
  .ab-intro { display: grid; grid-template-columns: 1fr; gap: 26px; padding: 24px 0; border-top: 1px solid var(--hair); }
  .ab-bio p { font-size: 17.5px; line-height: 1.6; margin: 0; }
  .ab-bio .ab-meta { font-size: 14px; color: var(--muted); margin-top: 14px; }

  /* bowtie program diagram */
  .bowtie { margin: 0; }
  .bowtie svg { width: 100%; height: auto; background: var(--panel); border: 1px solid var(--hair); border-radius: 12px; padding: 14px; }
  .bt-root { font-family: var(--mono); font-size: 18px; fill: var(--ink); }
  .bt-dom { font-family: var(--mono); font-size: 18px; fill: #fff; }
  .bt-hub { font-family: var(--display); font-size: 22px; font-weight: 600; fill: #fff; }
  .ub { fill: none; stroke: var(--muted); stroke-width: 1.4; stroke-linecap: round; stroke-linejoin: round; opacity: .55; }
  .bt-brace { font-family: var(--mono); font-size: 15px; letter-spacing: .1em; text-transform: uppercase; fill: var(--teal); }
  .bowtie figcaption { font-family: var(--mono); font-size: 12.5px; color: var(--muted); margin-top: 10px; max-width: 44em; line-height: 1.5; }

  .ab-life-lead { font-size: 15.5px; line-height: 1.6; color: var(--ink); max-width: 46em; margin: 28px 0 0; }
  .ab-life { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; max-width: 620px; margin: 0 auto; }
  .ab-life figure { margin: 0; }
  .ab-life img { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; object-position: center; border-radius: 12px; border: 1px solid var(--hair); background: var(--panel); display: block; }
  .ab-life figcaption { font-family: var(--mono); font-size: 11.5px; color: var(--muted); margin-top: 8px; line-height: 1.4; }

  .ab-block { border-top: 1px solid var(--hair); padding: 28px 0; }
  .ab-block h2 { font-family: var(--display); font-weight: 600; font-size: clamp(19px, 4vw, 23px); margin: 0 0 16px; }
  .ab-sub-h { font-size: 17px !important; margin: 22px 0 12px !important; }

  /* timeline */
  .timeline { list-style: none; margin: 0; padding: 0; }
  .timeline li { display: grid; grid-template-columns: 120px 1fr; gap: 22px; padding: 0 0 22px 0; position: relative; }
  .timeline li::before { content: ""; position: absolute; left: 132px; top: 6px; width: 9px; height: 9px; border-radius: 50%; background: var(--accent); }
  .timeline li::after { content: ""; position: absolute; left: 136px; top: 16px; bottom: -6px; width: 1px; background: var(--hair); }
  .timeline li:last-child::after { display: none; }
  .tl-when { font-family: var(--mono); font-size: 12.5px; color: var(--teal); padding-top: 2px; }
  .tl-body { padding-left: 22px; }
  .tl-where { font-family: var(--display); font-weight: 600; font-size: 17px; color: var(--indigo); }
  .tl-body p { font-size: 15.5px; line-height: 1.55; color: var(--muted); margin: 4px 0 0; }

  .ab-grid { display: grid; grid-template-columns: 1fr; gap: 0; }
  .ab-edu { display: grid; grid-template-columns: 110px 1fr; gap: 18px; padding: 9px 0; }
  .ab-when { font-family: var(--mono); font-size: 12px; color: var(--teal); }
  .ab-deg { font-size: 15.5px; font-weight: 600; color: var(--ink); }
  .ab-sub { font-size: 14px; color: var(--muted); }
  .ab-list { margin: 0; padding-left: 18px; }
  .ab-list li { font-size: 15px; line-height: 1.5; margin: 0 0 8px; }
  .ab-list.wide li { max-width: 60em; }

  .mentor-intro { font-size: 15px; line-height: 1.55; color: var(--muted); margin: 0 0 16px; max-width: 46em; }
  .mentor-list { list-style: none; margin: 0; padding: 0; }
  .mentor-list li { padding: 13px 0; border-top: 1px solid var(--hair); }
  .mentor-list li:first-child { border-top: 0; padding-top: 0; }
  .mn-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 4px 10px; }
  .mn-name { font-weight: 600; color: var(--ink); font-size: 17px; }
  .mn-meta { font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .mn-meta b { color: var(--ink); font-weight: 600; }
  .mn-cur { color: var(--accent); }
  .mn-did { font-size: 13.5px; line-height: 1.5; color: var(--muted); margin: 4px 0 0; max-width: 52em; }
  .mn-did a { color: var(--accent); text-decoration: none; }
  @media (hover: hover) { .mn-did a:hover { text-decoration: underline; } }

  .ab-links { display: flex; flex-wrap: wrap; gap: 8px; margin: 16px 0 0; }
  .ab-links a { font-family: var(--mono); font-size: 13px; border: 1px solid var(--hair); border-radius: 999px; padding: 9px 15px; color: var(--ink); background: var(--paper); transition: all .15s; }
  .ab-back { font-family: var(--mono); font-size: 13px; margin: 18px 0 8px; }

  @media (min-width: 680px) {
    .ab-intro { grid-template-columns: 0.82fr 1.18fr; gap: 36px; align-items: center; }
    .ab-grid { grid-template-columns: 1fr 1fr; gap: 40px; }
    .ab-grid .ab-block { border-top: 1px solid var(--hair); }
  }
  @media (max-width: 540px) {
    .ab-head { gap: 18px; }
    .ab-portrait { width: 116px; }
    .timeline li { grid-template-columns: 1fr; gap: 4px; }
    .timeline li::before, .timeline li::after { display: none; }
    .tl-body { padding-left: 0; }
  }
  @media (hover: hover) {
    .ab-links a:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-1px); }
  }
</style>
