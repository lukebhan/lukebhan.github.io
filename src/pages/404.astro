---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const title = '404 · Luke Bhan';
const description = 'Page not found.';
---
<Base title={title} description={description}>
  <Nav base="/" />
  <main>
    <section class="nf">
      <div class="wrap">
        <p class="eyebrow">404</p>
        <h1>This page wandered off.</h1>
        <p class="nf-lead">The page you are looking for does not exist or has moved.</p>
        <p class="nf-back"><a href="/">← Back to home</a></p>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .nf { padding: 64px 0; }
  .nf h1 { font-family: var(--display); font-weight: 600; font-size: clamp(28px, 7vw, 40px); line-height: 1.05; letter-spacing: -.02em; margin: 8px 0 0; color: var(--ink); }
  .nf-lead { font-size: 17px; line-height: 1.6; color: var(--muted); margin: 14px 0 0; max-width: 40em; }
  .nf-back { font-family: var(--mono); font-size: 13px; margin: 24px 0 0; }
</style>
